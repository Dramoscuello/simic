# Base de datos
USER_POSTGRES=SIMIC
PASS_POSTGRES=CAMBIA_ESTA_PASSWORD
DB_POSTGRES=SIMIC_db
HOST_POSTGRES=localhost
PORT_POSTGRES=5432

# Seguridad
SECRET_KEY=CAMBIA_ESTA_CLAVE_LARGA_Y_ALEATORIA

# Infraestructura
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:5173

# Notificaciones por correo (opcional)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion
MAIL_FROM=tu_correo@gmail.com
MAIL_PORT=465
MAIL_SERVER=smtp.gmail.com

# Proveedores de IA
# Las API keys se configuran exclusivamente por variables de entorno.
# La plataforma usa OpenAI y Anthropic según la tarea; si falta alguna,
# las funciones que la requieran se omitirán o fallarán gracefulmente.
OPENAI_API_KEY=sk-...
CLAUDE_API_KEY=sk-ant-...

# Endpoint personalizado compatible con la API de OpenAI (opcional).
# Útil para usar Ollama local u otro proxy: http://localhost:11434/v1
OPENAI_BASE_URL=

# Modelo por defecto para generación de simulacros (opcional).
# Puede ser un modelo OpenAI (gpt-*, o3, o1) o Anthropic Claude (claude-*).
DEFAULT_GENERATION_MODEL=o3

# Wolfram Alpha (usado en la validación matemática de preguntas)
WOLFRAM_APP_ID=...

# Simulacros
SIMULACRO_MARGIN_MINUTES=5
SIMULACRO_MIN_FINISH_PCT=0.30
